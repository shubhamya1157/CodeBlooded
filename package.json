{
  "name": "campusconnect",
  "version": "1.0.0",
  "description": "Campus event management microservices platform",
  "private": true,
  "workspaces": [
    "backend/services/*",
    "backend/shared",
    "frontend"
  ],
  "scripts": {
    "start": "docker-compose up -d",
    "stop": "docker-compose down",
    "dev:auth": "npm run dev --workspace=backend/services/user-auth-service",
    "dev:events": "npm run dev --workspace=backend/services/event-management-service",
    "dev:registration": "npm run dev --workspace=backend/services/registration-notification-service",
    "dev:gateway": "npm run dev --workspace=backend/services/api-gateway",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "npm-run-all --parallel dev:*"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
